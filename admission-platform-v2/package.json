      "react-dom": "^18.3.1",
      "@types/react": "^18.3.27",
      "@types/react-dom": "^18.3.7"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
