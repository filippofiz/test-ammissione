{
  "name": "admission-platform",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "import:gmat": "npx tsx GMAT/scripts/import-gmat-questions.ts",
    "import:gmat:dry": "npx tsx GMAT/scripts/import-gmat-questions.ts --dry-run --all",
    "compile:materials": "npx tsx GMAT/scripts/compile-materials.ts --all",
    "compile:materials:dry": "npx tsx GMAT/scripts/compile-materials.ts --dry-run --all",
    "upload:materials": "npx tsx GMAT/scripts/upload-gmat-materials.ts --all",
    "upload:materials:dry": "npx tsx GMAT/scripts/upload-gmat-materials.ts --dry-run --all"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "tsx": "^4.7.0",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "@types/react": "^18.3.27",
      "@types/react-dom": "^18.3.7"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
